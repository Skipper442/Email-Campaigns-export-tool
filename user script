  function refreshTemplateOptions() {
    const panel = getPanel();
    if (!panel) return;

    const select = panel.querySelector('#tmec-template-select');
    if (!select) return;

    const currentValue = select.value;
    const options = extractCRMTemplateOptions();

    select.innerHTML = options.map(option => `
      <option value="${escapeHtml(option.value)}">${escapeHtml(option.text)}</option>
    `).join('');

    if ([...select.options].some(option => option.value === currentValue)) {
      select.value = currentValue;
    }
  }

  function observeCRMTemplateSelect() {
    const sourceSelect = document.querySelector(CONFIG.crmEmailTemplateSelector);
    if (!sourceSelect) return;

    const observer = new MutationObserver(() => {
      refreshTemplateOptions();
    });

    observer.observe(sourceSelect, {
      childList: true,
      subtree: true,
      attributes: true
    });
  }

