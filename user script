  async function init() {
    try {
      restoreCollapsedState();
      injectStyles();
      setTimeout(createPanel, 50);

      await waitForElement(CONFIG.tableSelector, 20000);
      await waitForElement(CONFIG.crmEmailTemplateSelector, 20000);

      refreshTemplateOptions();
      observeCRMTemplateSelect();
      refreshActionLayout();
      setStatus('Table and CRM templates found. Ready to export.', 'success');
    } catch (error) {
      console.error('[TM Export] Init failed:', error);
      createPanel();
      refreshActionLayout();
      setStatus('Some source elements were not found yet. Reload page when report is fully visible.', 'error');
    }
  }

  init();
